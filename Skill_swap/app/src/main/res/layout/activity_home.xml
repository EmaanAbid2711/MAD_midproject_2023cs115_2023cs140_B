<?xml version="1.0" encoding="utf-8"?>

<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0FFC2">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F0FFC2">

        <!-- TOP BAR -->
        <LinearLayout
            android:orientation="horizontal"
            android:padding="10dp"
            android:background="#B5E18B"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/btnMenu"
                android:text="☰"
                android:textSize="24sp"
                android:textColor="#28396C"
                android:padding="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Home"
                android:textSize="18sp"
                android:textColor="#28396C"
                android:layout_marginStart="10dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>

        <!-- INPUTS -->
        <EditText
            android:id="@+id/etSkillHave"
            android:hint="Skill Have"
            android:backgroundTint="#28396C"
            android:textColor="#28396C"
            android:textColorHint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="48dp"/>

        <EditText
            android:id="@+id/etSkillWant"
            android:hint="Skill Want"
            android:backgroundTint="#28396C"
            android:textColor="#28396C"
            android:textColorHint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="48dp"/>

        <Spinner
            android:id="@+id/spinnerLevel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/spinner_bg"
            android:popupBackground="#B5E18B"
            android:padding="8dp"/>

        <Button
            android:id="@+id/btnAdd"
            android:text="Add Skill"
            android:textColor="#EAE6BC"
            android:backgroundTint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

    </LinearLayout>

    <!-- DRAWER -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_gravity="start"
        android:layout_width="250dp"
        android:layout_height="match_parent"
        android:background="#EAE6BC">

        <include layout="@layout/nav_header"/>

        <Button
            android:id="@+id/btnProfileDrawer"
            android:text="Profile"
            android:textColor="#EAE6BC"
            android:backgroundTint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnSearchDrawer"
            android:text="Search Match"
            android:textColor="#EAE6BC"
            android:backgroundTint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnRequestsDrawer"
            android:text="View Requests"
            android:textColor="#EAE6BC"
            android:backgroundTint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnLogoutDrawer"
            android:text="Logout"
            android:textColor="#EAE6BC"
            android:backgroundTint="#28396C"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>